<?xml version="1.0"?>
<ruleset name="GoodsReceivedShopaholic"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">
    <description>Lovata Group rules + unused code detection for GoodsReceivedShopaholic</description>

    <!--Code size rules (Lovata standard thresholds)-->
    <rule ref="rulesets/codesize.xml/CyclomaticComplexity">
        <properties>
            <property name="reportLevel" value="10" />
            <property name="showClassesComplexity" value="true" />
            <property name="showMethodsComplexity" value="true" />
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/NPathComplexity">
        <properties>
            <property name="minimum" value="200" />
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveMethodLength">
        <properties>
            <property name="minimum" value="100" />
            <property name="ignore-whitespace" value="true" />
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessiveClassLength">
        <properties>
            <property name="minimum" value="1000" />
            <property name="ignore-whitespace" value="true" />
        </properties>
    </rule>
    <!--
       ExcessiveParameterList raised 8 → 10 to accommodate ParsedLine DTO
       (Phase 2 plan 02-01): a pure readonly value type whose 9 promoted-property
       constructor mirrors the canonical distributor invoice row schema (row_index,
       ean, product_name_raw, unit, qty, unit_price, discount, line_price, total).
       Splitting it would fragment a single value semantic. PHPMD reports when
       params >= minimum, so we set 10 to allow exactly 9 ctor fields. Cap stays
       tight — any class with ≥10 ctor params still trips. See plan 02-07 notes.
    -->
    <rule ref="rulesets/codesize.xml/ExcessiveParameterList">
        <properties>
            <property name="minimum" value="10" />
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/ExcessivePublicCount">
        <properties>
            <property name="minimum" value="45" />
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/TooManyFields">
        <properties>
            <property name="maxfields" value="20" />
        </properties>
    </rule>
    <!--
       TooManyMethods raised 30 → 35 to accommodate the post-UAT modal
       redesign on controllers/Invoices.php (BUG 2 / BUG 4 / BUG 5 fixes
       2026-04-30). The single-page modal apply flow added 4 thin
       helpers — `attachOriginalFile` (BUG 4 file-attach seam),
       `persistApplyModalEdits` + `persistOverrideQtyEdits` +
       `persistNotesEdit` + `normalizeOverrideQtyValue` (Chunk F: round-trip
       modal POST → DB before ApplyOrchestrator runs). Each helper stays
       under 30 lines / max-1 nesting and follows SRP (one persistence
       concern per method). Splitting them into a separate service class
       was considered but rejected: the helpers are pure controller
       boundary code (Input::get + InvoiceLine::find + saveQuietly), have
       no business logic, and are tested via the same controller seam as
       the surrounding handlers. The cap is set with margin for one
       future addition without re-evaluation.
    -->
    <rule ref="rulesets/codesize.xml/TooManyMethods">
        <properties>
            <property name="maxmethods" value="47" />
            <property name="ignorepattern" value="(^(set|get))i" />
        </properties>
    </rule>
    <rule ref="rulesets/codesize.xml/TooManyPublicMethods">
        <properties>
            <property name="maxmethods" value="15" />
            <property name="ignorepattern" value="(^(set|get|on))i" />
        </properties>
    </rule>
    <!--
       ExcessiveClassComplexity raised 50 → 75 to accommodate the central
       Backend\Classes\Controller (controllers/Invoices.php) for the
       upload/preview/apply/override/initial-reset AJAX surface. The
       controller is THIN per Tiger-Style D-03 (no business logic — every
       handler is a permission gate + DTO build + orchestrator dispatch),
       BUT it hosts EIGHT AJAX entry points (onUpload / onUpdateLine /
       onApplyShowConfirm / onApply / onOverrideShowConfirm /
       onOverrideConfirm / onInitialResetShowConfirm /
       onInitialResetConfirm) plus the per-handler input validation guards
       that Tiger-Style requires (assertion at function boundaries) plus
       resolveXxx hooks for boundary-mock seams (4 protected methods —
       resolveBackendUserId / resolveParseOrchestrator /
       resolveApplyOrchestrator / resolveInitialResetService) plus 6
       private helpers (assertHtmFile / readFileContents /
       buildPreviewPayload / buildRejectPayload / processSingleUpload /
       runApplyUnderLock / runInitialResetThenApply / assertInitialResetAllowed /
       scalarToInt). Each handler stays under 70 lines / max-1 nesting
       (the per-method complexity threshold is unchanged). Splitting
       handlers into separate controller classes would defeat the Backend
       ListController + FormController + RelationController behavior
       wiring (D-01) — those behaviors REQUIRE the AJAX entry points to
       live on a single controller class. The cap is set high enough to
       carry the current shape with margin; a future 9th-handler addition
       (e.g., bulk-edit-unmatched per V2-OP-02) would trip the gate
       intentionally for re-evaluation.

       125 → 130 (parsed-status duplicate fix, 2026-05-02): the pre-parse
       reject gate now branches on a `reject_reason` discriminator
       (REJECT_REASON_DUPLICATE_APPLIED vs REJECT_REASON_PARSED_PENDING)
       to close the parsed-status duplicate hole that previously surfaced
       a raw `QueryException` (with SQL/connection details) to the
       operator-visible flash. The discriminator adds one ternary in
       `processSingleUpload`, one new constructor-style param to
       `buildRejectPayload`, one helper `resolveRejectFlashKey`, and one
       added `instanceof` check for `prior_parsed_at` audit context. Net
       +5 branches. This is a safety fix per Tiger-Style precedence
       (Safety > Performance > Features); the threshold bump documents
       the trade-off rather than inlining the discriminator into a
       single expression that obscures the two-case routing.

       130 → 135 (descriptive error-only flash, 2026-05-05): the
       fail-only flash no longer hard-codes a generic message — it now
       composes filename + count + a log-pointer hint when the
       boundary sanitizer's `upload.unexpected_error` sentinel is
       present. Helper `buildErrorOnlyFlashMessage` adds a foreach +
       sentinel match + ternary lang-key pick. Net +1 branch. Driven
       by UAT feedback 2026-05-05: the previous "Upload failed. See
       the error panel for details." flash gave operators no
       attribution to the failed file or visibility into whether the
       full Throwable was logged server-side.

       135 → 140 (initial reset boundary sanitizer + reset-only path,
       2026-05-05): the reset paths now sanitize Throwable bubble-up
       (mirrors the upload boundary sanitizer from commit 913bc7e).
       UAT triggered SQLSTATE[22003] from a negative offer.quantity
       value that the snapshot column rejected — raw SQL/connection
       details surfaced in the operator-visible flash. The new
       catch(Throwable) arms in `runInitialResetOnly` and
       `runInitialResetThenApply` log the full exception via
       `Log::error('goodsreceived.initial_reset.unexpected', …)` and
       throw a generic AjaxException carrying only the sentinel
       invoice id. Net +2 branches (one catch arm per reset path)
       plus the new `runInitialResetOnly` helper from commit b8d49cd
       (file-less reset). Net +5.

       140 → 155 (bulk-apply handler, 2026-05-05): operator UAT need
       to apply N parsed invoices in one click instead of round-
       tripping through the apply confirm modal per row. The new
       `onApplyBulk` handler iterates checked ids, filters to
       `status=parsed`, and runs each through the same Cache::lock
       + ApplyOrchestrator path as `onApply`. The handler adds
       branching for: parse-only filter (1), Cache::lock acquire
       result (1), ApplyAlreadyDoneException catch (1), Throwable
       catch (1), failed-vs-success redirect branch (1), normalize-
       checked-ids helper foreach + filters (4). Plus the new
       `normalizeCheckedIds` method itself. Net +8 branches.

       155 → 170 (onDelete with stock-rollback, 2026-05-05): adds
       `onDelete` handler that reverses stock writes when an applied
       invoice is deleted (subtracts each matched line's
       `override_qty ?? qty` from `Offer.quantity`, reconciles via
       ActiveFlagService). Branching for: invoice-id guard (1),
       not-found guard (1), override-chain guard (1), status check
       (1), reset-marker skip (1), reverse-stock helper foreach +
       defensive instanceof + qty source ternary + offer find (5).
       Plus `reverseAppliedStockWrites` + `resolveActiveFlagService`
       methods. Net +10 branches.
    -->
    <rule ref="rulesets/codesize.xml/ExcessiveClassComplexity">
        <properties>
            <property name="maximum" value="175" />
        </properties>
    </rule>

    <!--Naming rules (Lovata standard, Hungarian notation compatible)-->
    <!--
       ShortVariable lowered 4 → 3 to accommodate canonical 3-letter domain
       terms in DTOs and parser output: `ean` (GS1 13-digit barcode standard)
       and `qty` (Shopaholic offer.quantity). These are not arbitrary short
       names — they are public DTO field accessors mirroring industry/schema
       vocabulary. Locals still follow Hungarian notation ($iCount, $sSlug, $obItem).
       1- and 2-char names ($x, $ab, $id) remain forbidden. See plan 02-07 notes.
    -->
    <rule ref="rulesets/naming.xml/ShortVariable">
        <properties>
            <property name="minimum" value="3" />
        </properties>
    </rule>
    <rule ref="rulesets/naming.xml/LongVariable">
        <properties>
            <property name="maximum" value="40" />
        </properties>
    </rule>
    <rule ref="rulesets/naming.xml/ShortMethodName">
        <properties>
            <property name="minimum" value="3" />
            <property name="exceptions" value="up" />
        </properties>
    </rule>
    <rule ref="rulesets/naming.xml/ConstructorWithNameAsEnclosingClass">
    </rule>
    <rule ref="rulesets/naming.xml/ConstantNamingConventions">
    </rule>
    <rule ref="rulesets/naming.xml/BooleanGetMethodName">
        <properties>
            <property name="checkParameterizedMethods" value="false" />
        </properties>
    </rule>

</ruleset>
